# Copie este arquivo para .env e preencha os valores

# Gere uma chave secreta: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=sua-chave-secreta-aqui

# False para produção
DEBUG=False

# Domínio do seu app no Render (ex: petshop-pro.onrender.com)
ALLOWED_HOSTS=petshop-pro.onrender.com

# Database URL (o Render fornece isso automaticamente como variável de ambiente)
# DATABASE_URL=postgres://...